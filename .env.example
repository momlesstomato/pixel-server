# -----------------------------------------------------------------------------
# Global runtime
# -----------------------------------------------------------------------------
SERVICE_VERSION=dev
NODE_ID=local

# -----------------------------------------------------------------------------
# Logging (Zap)
# -----------------------------------------------------------------------------
LOG_FORMAT=pretty
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Infrastructure endpoints
# -----------------------------------------------------------------------------
NATS_URL=nats://localhost:4222
DATABASE_URL=postgres://pixel:pixel@localhost:5432/pixel?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Game service
# -----------------------------------------------------------------------------
PLUGINS_DIR=plugins

# -----------------------------------------------------------------------------
# Docker Compose support vars
# -----------------------------------------------------------------------------
POSTGRES_DB=pixel
POSTGRES_USER=pixel
POSTGRES_PASSWORD=pixel

# -----------------------------------------------------------------------------
# Optional packet debugging
# -----------------------------------------------------------------------------
PACKET_DEBUG=false
