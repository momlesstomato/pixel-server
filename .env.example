APP_BIND_IP=0.0.0.0
APP_PORT=3000
APP_NAME=pixel-server
APP_ENVIRONMENT=development
APP_API_KEY=change-me

REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20

POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/pixel_server?sslmode=disable
POSTGRES_MAX_OPEN_CONNS=30
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME_SECONDS=300

USERS_JWT_SECRET=change-me
USERS_PASSWORD_COST=12
USERS_SESSION_TTL_SECONDS=86400

LOGGING_FORMAT=console
LOGGING_LEVEL=info

AUTHENTICATION_DEFAULT_TTL_SECONDS=300
AUTHENTICATION_MAX_TTL_SECONDS=1800
AUTHENTICATION_KEY_PREFIX=sso
