APP_BIND_IP=0.0.0.0
APP_PORT=3000
APP_NAME=pixel-server
APP_ENVIRONMENT=development
APP_API_KEY=change-me

REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20

POSTGRES_DSN=postgres://postgres:postgres@127.0.0.1:5432/pixel_server?sslmode=disable
POSTGRES_MAX_OPEN_CONNS=30
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_CONN_MAX_LIFETIME_SECONDS=300
POSTGRES_MIGRATION_AUTO_UP=false
POSTGRES_SEED_AUTO_UP=false
POSTGRES_MIGRATION_TABLE=schema_migrations
POSTGRES_SEED_TABLE=schema_seeds

USERS_JWT_SECRET=change-me
USERS_PASSWORD_COST=12
USERS_SESSION_TTL_SECONDS=86400
USERS_SETTINGS_ROOM_INVITES_PACKET_ID=65534
USERS_SETTINGS_OLD_CHAT_PACKET_ID=65535
USERS_UNIGNORE_PACKET_ID=65533
USERS_IGNORE_BY_ID_PACKET_ID=65532
USERS_APPROVE_NAME_PACKET_ID=65531

LOGGING_FORMAT=console
LOGGING_LEVEL=info

AUTHENTICATION_DEFAULT_TTL_SECONDS=300
AUTHENTICATION_MAX_TTL_SECONDS=1800
AUTHENTICATION_KEY_PREFIX=sso

STATUS_OPEN_HOUR=0
STATUS_OPEN_MINUTE=0
STATUS_CLOSE_HOUR=23
STATUS_CLOSE_MINUTE=59
STATUS_REDIS_KEY=hotel:status
STATUS_BROADCAST_CHANNEL=broadcast:all
STATUS_COUNTDOWN_TICK_SECONDS=60
STATUS_DEFAULT_MAINTENANCE_DURATION_MINUTES=15

PERMISSION_CACHE_PREFIX=perm:group
PERMISSION_CACHE_TTL_SECONDS=300
PERMISSION_AMBASSADOR_PERMISSION=role.ambassador
PERMISSION_EMIT_PERMISSION_CHECKED=false

MESSENGER_MAX_FRIENDS=200
MESSENGER_MAX_FRIENDS_VIP=500
MESSENGER_FLOOD_COOLDOWN_MS=750
MESSENGER_FLOOD_VIOLATIONS=4
MESSENGER_FLOOD_MUTE_SECONDS=20
MESSENGER_OFFLINE_MSG_TTL_DAYS=30
MESSENGER_MESSAGE_LOG_TTL_DAYS=30
MESSENGER_PURGE_INTERVAL_SECONDS=3600
MESSENGER_FRAGMENT_SIZE=750
